{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/jogos/[eventId]/live",
      "regex": "^/jogos/([^/]+?)/live(?:/)?$",
      "routeKeys": {
        "nxtPeventId": "nxtPeventId"
      },
      "namedRegex": "^/jogos/(?<nxtPeventId>[^/]+?)/live(?:/)?$"
    },
    {
      "page": "/jogos/[eventId]/stats",
      "regex": "^/jogos/([^/]+?)/stats(?:/)?$",
      "routeKeys": {
        "nxtPeventId": "nxtPeventId"
      },
      "namedRegex": "^/jogos/(?<nxtPeventId>[^/]+?)/stats(?:/)?$"
    },
    {
      "page": "/live/[id]",
      "regex": "^/live/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/live/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/configuracoes",
      "regex": "^/configuracoes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/configuracoes(?:/)?$"
    },
    {
      "page": "/configuracoes/importar",
      "regex": "^/configuracoes/importar(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/configuracoes/importar(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/estatisticas",
      "regex": "^/estatisticas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/estatisticas(?:/)?$"
    },
    {
      "page": "/jogadores",
      "regex": "^/jogadores(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/jogadores(?:/)?$"
    },
    {
      "page": "/jogos",
      "regex": "^/jogos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/jogos(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/pagamentos",
      "regex": "^/pagamentos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pagamentos(?:/)?$"
    },
    {
      "page": "/temporadas",
      "regex": "^/temporadas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/temporadas(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}