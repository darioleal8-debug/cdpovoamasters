# ══════════════════════════════════════════════════════════════
#  Masters CD Póvoa — variáveis de ambiente
#  Copiar para .env.local e preencher com os valores reais.
#  NUNCA commitar .env.local no repositório.
# ══════════════════════════════════════════════════════════════

# Supabase — criar projeto em https://supabase.com
# Settings > API > Project URL e anon/service keys
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Apenas para operações server-side que requerem bypass de RLS
# (ex: seed de admin, migrations)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
